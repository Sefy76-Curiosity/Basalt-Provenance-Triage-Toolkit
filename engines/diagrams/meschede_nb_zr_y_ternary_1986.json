  "version": "1.0",
  "author": "Meschede, M.",
  "reference": {
    "citation": "Meschede, M. (1986). A method of discriminating between different types of mid-ocean ridge basalts and continental tholeiites with the Nb-Zr-Y diagram. Chemical Geology, 56(3-4), 207-218",
