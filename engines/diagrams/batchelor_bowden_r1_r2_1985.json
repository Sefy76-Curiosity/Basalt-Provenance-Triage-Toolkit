  "diagram_name": "Batchelor & Bowden R1-R2 Multicationic Diagram",
  "version": "1.0",
  "author": "Batchelor, R.A. & Bowden, P.",
  "reference": {
    "citation": "Batchelor, R.A. & Bowden, P. (1985). Petrogenetic interpretation of granitoid rock series using multicationic parameters. Chemical Geology, 48(1-4), 43-55",
    "doi": "10.1016/0009-2541(85)90034-8",
    "figure": "Figure 2"
  },
  "description": "R1 = 4Si - 11(Na+K) - 2(Fe+Ti) vs R2 = 6Ca + 2Mg + Al for granitoid tectonic settings",
  "diagram_type": "xy",

  "requires_fields": ["SiO2_wt", "Na2O_wt", "K2O_wt", "FeO_T_wt", "TiO2_wt", "CaO_wt", "MgO_wt", "Al2O3_wt"],

  "derived_fields": [
    {
      "name": "R1",
      "formula": "(4 * (SiO2_wt/60.08) * 1000) - (11 * ((Na2O_wt/61.98) + (K2O_wt/94.2)) * 1000) - (2 * ((FeO_T_wt/71.85) + (TiO2_wt/79.9)) * 1000)",
      "requires": ["SiO2_wt", "Na2O_wt", "K2O_wt", "FeO_T_wt", "TiO2_wt"],
      "description": "R1 parameter (cation proportions)"
    },
    {
      "name": "R2",
      "formula": "(6 * (CaO_wt/56.08) * 1000) + (2 * (MgO_wt/40.3) * 1000) + ((Al2O3_wt/101.96) * 1000)",
      "requires": ["CaO_wt", "MgO_wt", "Al2O3_wt"],
      "description": "R2 parameter (cation proportions)"
    }
  ],

  "axes": {
    "x": {
      "field": "R1",
      "label": "R1 = 4Si - 11(Na+K) - 2(Fe+Ti)",
