      "label": "SiO₂ (wt%)",
      "scale": "linear",
      "limits": [50, 80],
      "major_ticks": [50, 55, 60, 65, 70, 75, 80],
      "grid": true
    },
    "y": {
      "field": "Al2O3_wt",
      "label": "Al₂O₃ (wt%)",
      "scale": "linear",
      "limits": [10, 20],
      "major_ticks": [10, 12, 14, 16, 18, 20],
      "grid": true
    }
  },

  "fields": [
    {
      "name": "Island Arc",
      "type": "polygon",
      "points": [[50, 16], [68, 16], [68, 18.5], [50, 18.5]],
      "closed": true,
      "color": "#87CEEB",
      "alpha": 0.2,
      "label": "Island Arc",
      "tooltip": "IAG - Island Arc Granitoids"
    },
    {
      "name": "Continental Arc",
      "type": "polygon",
      "points": [[50, 14], [70, 14], [70, 16], [50, 16]],
      "closed": true,
      "color": "#98FB98",
      "alpha": 0.2,
      "label": "Continental Arc",
      "tooltip": "CAG - Continental Arc Granitoids"
    },
    {
      "name": "Active Continental Margin",
      "type": "polygon",
      "points": [[55, 12], [75, 12], [75, 14], [55, 14]],
      "closed": true,
      "color": "#F4A460",
      "alpha": 0.2,
      "label": "Active Continental Margin",
      "tooltip": "ACM - Active Continental Margin"
    },
    {
      "name": "Passive Margin",
      "type": "polygon",
      "points": [[60, 10], [80, 10], [80, 12], [60, 12]],
      "closed": true,
      "color": "#FFB6C1",
      "alpha": 0.2,
      "label": "Passive Margin",
      "tooltip": "PM - Passive Margin (including POG, RRG, CEUG)"
    }
  ],

  "lines": [
    {
      "name": "Upper boundary IAG",
