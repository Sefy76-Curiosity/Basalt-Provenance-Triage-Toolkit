{
  "schema_version": "1.0",
  "diagram_id": "maniar_piccoli_al2o3_sio2_1989",
  "diagram_name": "Maniar & Piccoli Al₂O₃ vs SiO₂ Tectonic Discrimination",
  "version": "1.0",
  "author": "Maniar, P.D. & Piccoli, P.M.",
  "reference": {
    "citation": "Maniar, P.D. & Piccoli, P.M. (1989). Tectonic discrimination of granitoids. Geological Society of America Bulletin, 101(5), 635-643",
