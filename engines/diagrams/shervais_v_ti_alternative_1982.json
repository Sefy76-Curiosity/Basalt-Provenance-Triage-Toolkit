{
  "schema_version": "1.0",
  "diagram_id": "shervais_v_ti_alternative_1982",
  "diagram_name": "Shervais V vs Ti Alternative Discrimination",
  "version": "1.0",
  "author": "Shervais, J.W.",
  "reference": {
    "citation": "Shervais, J.W. (1982). Ti-V plots and the petrogenesis of modern and ophiolitic lavas. Earth and Planetary Science Letters, 59(1), 101-118",
    "doi": "10.1016/0012-821X(82)90120-0",
    "figure": "Figure 3"
  },
  "description": "V vs Ti discrimination diagram for basalts with Ti/V ratio lines (alternative orientation)",
  "diagram_type": "xy",

  "requires_fields": ["V_ppm", "Ti_ppm"],

  "derived_fields": [
    {
      "name": "Ti_V",
      "formula": "Ti_ppm / V_ppm",
      "requires": ["Ti_ppm", "V_ppm"],
      "description": "Ti/V ratio"
    }
  ],

  "axes": {
    "x": {
      "field": "V_ppm",
      "label": "V (ppm)",
      "scale": "log",
      "limits": [10, 1000],
      "major_ticks": [10, 100, 1000],
      "grid": true
    },
    "y": {
      "field": "Ti_ppm",
      "label": "Ti (ppm)",
      "scale": "log",
      "limits": [100, 100000],
      "major_ticks": [100, 1000, 10000, 100000],
      "grid": true
    }
  },

  "lines": [
    {
      "name": "Ti/V = 10",
      "type": "line",
      "points": [[10, 100], [1000, 10000]],
      "color": "gray",
      "linestyle": "--",
      "linewidth": 0.5,
      "alpha": 0.5
    },
    {
      "name": "Ti/V = 20",
      "type": "line",
      "points": [[10, 200], [1000, 20000]],
      "color": "gray",
      "linestyle": "--",
      "linewidth": 0.5,
      "alpha": 0.5
    },
    {
      "name": "Ti/V = 50",
      "type": "line",
      "points": [[10, 500], [1000, 50000]],
      "color": "gray",
      "linestyle": "--",
      "linewidth": 0.5,
      "alpha": 0.5
    },
    {
      "name": "Ti/V = 100",
      "type": "line",
      "points": [[10, 1000], [1000, 100000]],
      "color": "gray",
      "linestyle": "--",
      "linewidth": 0.5,
      "alpha": 0.5
    }
  ],

  "fields": [
    {
      "name": "MORB & BABB",
      "type": "polygon",
      "points": [[200, 4000], [500, 4000], [500, 20000], [200, 20000]],
      "closed": true,
      "color": "#87CEEB",
      "alpha": 0.2,
      "label": "MORB & BABB",
      "tooltip": "Mid-Ocean Ridge and Back-Arc Basin Basalts (Ti/V 20-50)"
    },
    {
      "name": "IAT",
      "type": "polygon",
      "points": [[200, 2000], [400, 2000], [400, 4000], [200, 4000]],
      "closed": true,
      "color": "#F4A460",
      "alpha": 0.2,
      "label": "IAT",
      "tooltip": "Island Arc Tholeiites (Ti/V 10-20)"
    },
    {
      "name": "Boninite",
      "type": "polygon",
      "points": [[100, 500], [250, 500], [250, 2000], [100, 2000]],
      "closed": true,
      "color": "#DDA0DD",
      "alpha": 0.2,
      "label": "Boninite",
      "tooltip": "Boninites (Ti/V < 10)"
    },
    {
      "name": "OIB & Alkaline",
      "type": "polygon",
      "points": [[200, 20000], [400, 20000], [400, 50000], [200, 50000]],
      "closed": true,
      "color": "#FFB6C1",
      "alpha": 0.2,
      "label": "OIB & Alkaline",
      "tooltip": "Ocean Island and Alkaline Basalts (Ti/V > 50)"
    }
  ],

  "annotations": [
    {
      "text": "Ti/V=10",
      "position": [800, 7000],
      "fontsize": 6,
      "rotation": 45,
      "alpha": 0.5
    },
    {
      "text": "Ti/V=20",
      "position": [800, 14000],
      "fontsize": 6,
      "rotation": 45,
      "alpha": 0.5
    },
    {
      "text": "Ti/V=50",
      "position": [800, 35000],
      "fontsize": 6,
      "rotation": 45,
      "alpha": 0.5
    },
    {
      "text": "Ti/V=100",
      "position": [800, 70000],
      "fontsize": 6,
      "rotation": 45,
      "alpha": 0.5
    }
  ],

  "sample_plotting": {
    "default_marker": "o",
    "default_size": 30,
    "default_color": "red",
    "default_edgecolor": "black",
    "default_alpha": 0.8
  },

  "legend": {
    "position": "upper left",
    "fontsize": 8
  }
}
