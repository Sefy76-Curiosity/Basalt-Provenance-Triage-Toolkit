{
  "schema_version": "1.0",
  "diagram_id": "fitton_nb_zr_y_zr_1997",
  "diagram_name": "Fitton Nb/Zr vs Y/Zr Basalt Discrimination",
  "version": "1.0",
  "author": "Fitton, J.G. et al.",
  "reference": {
    "citation": "Fitton, J.G., Saunders, A.D., Norry, M.J., Hardarson, B.S. & Taylor, R.N. (1997). Thermal and chemical structure of the Iceland plume. Earth and Planetary Science Letters, 153(3-4), 197-208",
    "doi": "10.1016/S0012-821X(97)00170-2",
    "figure": "Adapted from Nb/Zr–Y/Zr fields discussed in plume vs non-plume basalts"
  },
  "description": "Nb/Zr vs Y/Zr discrimination diagram for basalts: N-MORB, E-MORB, OIB, and Arc-related basalts",
