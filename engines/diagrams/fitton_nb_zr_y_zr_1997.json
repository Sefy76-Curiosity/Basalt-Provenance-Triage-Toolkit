      "requires": ["Nb_ppm", "Zr_ppm"],
      "description": "Nb/Zr ratio"
    },
    {
      "name": "Y_Zr",
      "formula": "Y_ppm / Zr_ppm",
      "requires": ["Y_ppm", "Zr_ppm"],
      "description": "Y/Zr ratio"
    }
  ],

  "axes": {
    "x": {
      "field": "Nb_Zr",
      "label": "Nb/Zr",
      "scale": "linear",
      "limits": [0.0, 0.2],
      "major_ticks": [0.0, 0.05, 0.10, 0.15, 0.20],
      "grid": true
    },
    "y": {
