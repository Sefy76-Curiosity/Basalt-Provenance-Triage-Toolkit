      "alpha": 0.15,
      "label": "BAB (Ti/V 8-15)"
    },
    {
      "name": "OIB",
      "type": "polygon",
      "points": [[150, 15000], [300, 15000], [300, 30000], [150, 30000]],
      "closed": true,
      "color": "#FFB6C1",
      "alpha": 0.15,
      "label": "OIB (Ti/V 50-100)"
