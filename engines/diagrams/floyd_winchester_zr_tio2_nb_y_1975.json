{
  "schema_version": "1.0",
  "diagram_id": "floyd_winchester_zr_tio2_nb_y_1975",
  "diagram_name": "Floyd & Winchester Zr/TiO₂ vs Nb/Y Rock Classification",
  "version": "1.0",
  "author": "Floyd, P.A. & Winchester, J.A.",
  "reference": {
    "citation": "Floyd, P.A. & Winchester, J.A. (1975). Magma type and tectonic setting discrimination using immobile elements. Earth and Planetary Science Letters, 27(2), 211-220",
    "doi": "10.1016/0012-821X(75)90031-X",
    "figure": "Figure 2"
  },
  "description": "Zr/TiO₂ vs Nb/Y discrimination diagram for volcanic rocks (especially altered samples)",
  "diagram_type": "xy",

  "requires_fields": ["Zr_ppm", "TiO2_wt", "Nb_ppm", "Y_ppm"],

  "derived_fields": [
    {
      "name": "Zr_TiO2",
      "formula": "Zr_ppm / (TiO2_wt * 10000)",
      "requires": ["Zr_ppm", "TiO2_wt"],
      "description": "Zr/TiO₂ ratio (TiO₂ in wt% converted to ppm equivalent)"
    },
    {
      "name": "Nb_Y",
      "formula": "Nb_ppm / Y_ppm",
      "requires": ["Nb_ppm", "Y_ppm"],
      "description": "Nb/Y ratio"
    }
  ],

  "axes": {
    "x": {
      "field": "Nb_Y",
      "label": "Nb/Y",
      "scale": "log",
      "limits": [0.01, 10],
      "major_ticks": [0.01, 0.1, 1, 10],
      "grid": true
    },
    "y": {
      "field": "Zr_TiO2",
      "label": "Zr/TiO₂",
      "scale": "log",
      "limits": [0.001, 1],
      "major_ticks": [0.001, 0.01, 0.1, 1],
      "grid": true
    }
  },

