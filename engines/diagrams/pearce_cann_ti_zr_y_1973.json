{
  "schema_version": "1.0",
  "diagram_id": "pearce_cann_ti_zr_y_1973",
  "diagram_name": "Pearce & Cann Ti-Zr-Y Ternary Discrimination",
  "version": "1.0",
  "author": "Pearce, J.A. & Cann, J.R.",
  "reference": {
    "citation": "Pearce, J.A. & Cann, J.R. (1973). Tectonic setting of basic volcanic rocks determined using trace element analyses. Earth and Planetary Science Letters, 19(2), 290-300",
    "doi": "10.1016/0012-821X(73)90129-5",
    "figure": "Figure 4"
  },
  "description": "Ti/100 - Zr - Y*3 ternary discrimination diagram for basalts: Field A = Low-K tholeiites, B = Ocean-floor basalts, C = Calc-alkali basalts, D = Within-plate basalts",
  "diagram_type": "ternary",

  "requires_fields": ["Ti_ppm", "Zr_ppm", "Y_ppm"],

  "derived_fields": [
    {
      "name": "Ti_100",
      "formula": "Ti_ppm / 100",
      "requires": ["Ti_ppm"],
      "description": "Ti/100"
    },
    {
      "name": "Y_3",
      "formula": "Y_ppm * 3",
      "requires": ["Y_ppm"],
      "description": "Y*3"
    }
  ],

  "axes": {
    "a": {
      "field": "Ti_100",
      "label": "Ti/100",
      "scale": "linear",
      "limits": [0, 100],
      "major_ticks": [0, 20, 40, 60, 80, 100]
    },
    "b": {
      "field": "Zr_ppm",
      "label": "Zr",
      "scale": "linear",
      "limits": [0, 100],
      "major_ticks": [0, 20, 40, 60, 80, 100]
    },
    "c": {
      "field": "Y_3",
      "label": "Y*3",
      "scale": "linear",
      "limits": [0, 100],
      "major_ticks": [0, 20, 40, 60, 80, 100]
    }
  },

  "fields": [
    {
